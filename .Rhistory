player_models <- function(player_data, player_name) {
linear_fit <- lm(HR~Age, data=player_data)
quadratic_fit <- lm(HR~Age + I(Age^2), data=player_data)
cubic_fit <- lm(HR~Age + I(Age^2) + I(Age^3), data=player_data)
quartic_fit <- lm(HR~Age + I(Age^2) + I(Age^3) + I(Age^4), data=player_data)
models <- list(
Linear = linear_fit,
Quadratic = quadratic_fit,
Cubic = cubic_fit,
Quartic = quartic_fit
)
plot(player_data$HR ~ player_data$Age,
main = sprintf("%s's Home Run Models", player_name),
xlab = "Age",
ylab = "Number of Home Runs",
pch = 19)
age_seq <- seq(min(player_data$Age), max(player_data$Age), length.out = 100)
colors <- c("red", "blue", "green", "purple")
for (i in 1:length(models)) {
lines(age_seq,
predict(models[[i]], newdata = data.frame(Age = age_seq)),
col = colors[i],
lwd = 2)
}
legend("topleft",
legend = names(models),
col = colors,
lwd = 2)
return(models)
}
