library(glmnet)
library(mgcv)
library(MASS)
bordeaux <- read.csv("Bordeaux.csv")
model_ols <- lm(log(Price) ~ ParkerPoints + CoatesPoints + P95andAbove +
FirstGrowth + CultWine + Pomerol + VintageSuperstar,
data = bordeaux)
summary(model_ols)
## Function for regularized regression
fit_regularized <- function(X, y, alpha, method_name) {
# alpha = 0 for ridge, alpha = 1 for lasso
set.seed(123)
cv_model <- cv.glmnet(X, y, alpha = alpha)
plot(cv_model, main = paste(method_name, "Cross-Validation"))
lambda_min <- cv_model$lambda.min
lambda_1se <- cv_model$lambda.1se
cat(method_name, "Lambda min:", lambda_min, "\n")
cat(method_name, "Lambda 1se:", lambda_1se, "\n")
final_model <- glmnet(X, y, alpha = alpha, lambda = lambda_1se)
return(list(cv_model = cv_model,
final_model = final_model,
lambda_1se = lambda_1se,
coefficients = as.vector(coef(final_model))))
}
# Prepare data
X <- model.matrix(log(Price) ~ ParkerPoints + CoatesPoints + P95andAbove +
FirstGrowth + CultWine + Pomerol + VintageSuperstar,
data = bordeaux)[, -1]
y <- log(bordeaux$Price)
ridge_results <- fit_regularized(X, y, alpha = 0, method_name = "Ridge")
# Compare coefficients
coef_comparison_ridge <- data.frame(
OLS = coef(model_ols),
Ridge = ridge_results$coefficients
)
print(coef_comparison_ridge)
lasso_results <- fit_regularized(X, y, alpha = 1, method_name = "Lasso")
# Compare coefficients
coef_comparison_lasso <- data.frame(
OLS = coef(model_ols),
Ridge = ridge_results$coefficients,
Lasso = lasso_results$coefficients
)
print(coef_comparison_lasso)
gam_model <- gam(log(Price) ~ s(ParkerPoints) + s(CoatesPoints) +
P95andAbove + FirstGrowth + CultWine + Pomerol + VintageSuperstar,
data = bordeaux)
summary(gam_model)
par(mfrow = c(1, 2))
plot(gam_model, select = 1, main = "f1: ParkerPoints")
plot(gam_model, select = 2, main = "f2: CoatesPoints")
par(mfrow = c(1, 1))
summary(gam_model)$p.table
summary(model_ols)$coefficients
