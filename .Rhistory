library(vip)
# 1. Define the wrapper (this handles the binary probability output)
pfun <- function(object, newdata) {
predict(object, newdata, type = "prob")[, "1"]
}
# 2. Run Permutation Importance (the unbiased gold standard)
# We use nsim = 10 to get a more stable, average result
vi_results <- vi_permute(rf_strata,
target = "best_picture_winner",
metric = "accuracy",
pred_wrapper = pfun,
train = dat_vip,  # (Ensure 'dat_vip' has the factorized target)
nsim = 10)
library(vip)
# 1. Define the wrapper (this handles the binary probability output)
pfun <- function(object, newdata) {
predict(object, newdata, type = "prob")[, "1"]
}
# 2. Run Permutation Importance (the unbiased gold standard)
# We use nsim = 10 to get a more stable, average result
vi_results <- vi_permute(rf_strata,
target = "best_picture_winner",
metric = "auc",
pred_wrapper = pfun,
train = dat_vip,
nsim = 10)
library(vip)
# 1. Redefine the wrapper to return FACTORS, not probabilities
# 'vip' needs categories (0 or 1) to calculate accuracy.
pfun <- function(object, newdata) {
# Get predictions as factors
preds <- predict(object, newdata, type = "response") # Returns "0" or "1"
return(as.factor(preds))
}
# 2. Run Permutation Importance using "accuracy"
# This now matches because 'pfun' returns factors and 'dat_vip' has factors
vi_results <- vi_permute(rf_strata,
target = "best_picture_winner",
metric = "accuracy",
pred_wrapper = pfun,
train = dat_vip,
nsim = 10)
# 3. Plot it
vip(vi_results)
# Adding interaction term
interact.model.5 <- glm(formula = best_picture_winner ~ popcornmeter + total_academy_award_exclude_best_pic +
nominee_film_edit + best_director_award_before + best_director_award_now +
total_won_gg + budget_norm + post_2009*budget_norm, family = binomial, data = dat)
anova(final.model, interact.model.5, test = "Chisq")
final.model <- glm(formula = best_picture_winner ~ popcornmeter + total_academy_award_exclude_best_pic +
nominee_film_edit + best_director_award_before + best_director_award_now +
total_won_gg + budget_norm + post_2009*budget_norm, family = binomial, data = dat)
vif(final.model)
summary(final.model)
final.model <- glm(formula = best_picture_winner ~ popcornmeter + total_academy_award_exclude_best_pic +
nominee_film_edit + best_director_award_before + best_director_award_now +
total_won_gg + post_2009*budget_norm, family = binomial, data = dat)
vif(final.model)
summary(final.model)
View(interact.model.4)
residualPlots(final.model)
# Calculate Odds Ratios and 95% Confidence Intervals
# The percentage change in the winning probability for each unit increase in predictor
or_results <- exp(cbind(OR = coef(final.model), confint(final.model)))
print(or_results)
library(margins)
me <- margins(final.model)
summary(me)
# Calculate the AME of budget_norm for each era (0 and 1)
me_interaction <- margins(final.model,
at = list(post_2009 = c(0, 1)))
summary(me_interaction)
# Calculate the AME of budget_norm for each era (0 and 1)
me_interaction <- margins(final.model,
type = "response",
at = list(post_2009 = c(0, 1)))
summary(me_interaction)
# 1. Get the predicted probabilities (P) for every film
P <- predict(final.model, type = "response")
# 2. Extract the effective coefficients (beta)
# For pre-2009 (post_2009 = 0)
beta_pre <- coef(final.model)["budget_norm"]
# For post-2009 (post_2009 = 1)
# The effect of budget is budget_norm + (budget_norm * post_2009)
beta_post <- coef(final.model)["budget_norm"] + coef(final.model)["post_2009:budget_norm"]
# 3. Calculate the AME for each era
# Formula: AME = beta * mean(P * (1 - P))
# We filter P based on the post_2009 column in your data
ame_pre  <- beta_pre * mean(P[dat$post_2009 == 0] * (1 - P[dat$post_2009 == 0]))
ame_post <- beta_post * mean(P[dat$post_2009 == 1] * (1 - P[dat$post_2009 == 1]))
print(paste("Manual AME Pre-2009:", round(ame_pre, 4)))
print(paste("Manual AME Post-2009:", round(ame_post, 4)))
library(pROC)
# 1. Get predicted probabilities
probabilities <- predict(final.model, type = "response")
# 2. Create the ROC object
roc_obj <- roc(dat$best_picture_winner, probabilities)
# 3. Plot the curve
plot(roc_obj, main = paste("ROC Curve (AUC =", round(auc(roc_obj), 3), ")"))
