#### Principle component analysis
res <- prcomp(iris[,1:4], scale=T)
names(res)
names(res)
res$sdev
res$sdev^2
res$sdev^2/sum(res$sdev^2)
summary(res)
plot(res)
# A good example to do dimension reduction, because we are not throwing away a lot of information
# By throwing PC3 and PC4
# 95% of the information is compressed in 2-dimensional space
par(mfrow=c(1,1))
plot(res)
# PCA is mainly doing a rotation
names(res)
# we have rotation, how much it rotates each datapoint to its new location and new coordinate system
res$rotation
# Let's focus on the first principle component
rotation <- res$rotation[,1]
iris[1, 1:4]*rotation
sum(iris[1, 1:4]*rotation)
head(res$x)
# Apply the linear combination to all 4 variables
sum(iris1[1, 1:4]*rotation) # The coordinate of the first observation in a newly defined dimension
head(res$x)
