data(quakes)
head(quakes)
# Visualize
plot(quakes$long, quakes$lat, pch=19, cex=quakes$mag)
range(quakes$mag)
# Visualize
plot(quakes$long, quakes$lat, pch=19, cex=quakes$mag-3.9)
# Visualize the depth
range(quakes$depth)
# Define into 5 different categories of variables
depth_cut <- cut(quakes$depth, breaks=5)
depth_cut
head(depth_cut)
plot(quakes$long, quakes$lat, pch=19, col = cols, cex=quakes$mag-3.9)
# Define into 5 different categories of variables
depth_cut <- cut(quakes$depth, breaks=5)
cols <- as.numeric(depth_cut) # Into category
plot(quakes$long, quakes$lat, pch=19, col = cols, cex=quakes$mag-3.9)
install.packages("mgcViz")
# Fit a spatial modeling: Generalized Additive Models (GAM)
library(mgcv)
gam1 <- gam(mag~s(long,lat) + depth_cut)
summary(gam1)
gam1 <- gam(mag ~ s(long,lat) + depth_cut, data=quakes)
summary(gam1)
library(igraph)
install.packages("igraph")
library(igraph)
# Make up dataset
edges <- data.frame(frpm=c("A","B","C","C","D","E","F"),
to=c("B","C","A","D","E","F","D"))
# Undirected graph
g <- graph_from_data_frame(edges,directed=FALSE)
# Visualize
plot(g)
# Simple Summaries
degree(g)
# Community detection: clustering on network data
cl <- cluster_edge_betweenness(g)
membership(cl)
# Which cluster each node belongs to
plot(cl,g)
