x <- 1:10
chi.results <- rep(NA, times = repititions)
beta1 <- 2
beta0 <- 3
repititions <- 10000
chi.results <- rep(NA, times = repititions)
for (i in 1:repititions) {
chi_error <- -100 * (rchisq(n = sample.size, df = 1) - 1)
chi.y <- beta0 + beta1 * x + chi_error
chi.dat <- data.frame(x, chi.y)
chi.fit <- lm(chi.y ~ x, data = chi.dat)
chi.confidence.interval.beta.1 <- confint(chi.fit, parm = 2, level = confidence.level)
chi.results[i] <- isBetween(endpoints = chi.confidence.interval.beta.1, test.value = beta1)
chi.results <- rep(NA, times = repititions)
