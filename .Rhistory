# If we initialize at some pathological centers
# Centers exactly in between two clusters
c1 <- c(0,3)
c2 <- c(-1.5, 1.5)
c3 <- c(1.5, -1.5)
# Step 2: Iterate
nite <- 10 # number of iterations
for (i in 1:nite){
# Calculate the distance from the center to the datapoints
# And label the points based on the distance
d1 <- sqrt((x-c1[1])^2 + (y-c1[2])^2)
d2 <- sqrt((x-c2[1])^2 + (y-c2[2])^2)
d3 <- sqrt((x-c3[1])^2 + (y-c3[2])^2)
labels <- apply(cbind(d1,d2,d3), 1, which.min)
# Update the centers to the new centers of all the datapoints of the same label
c1 <- c(mean(x[which(labels==1)]), mean(y[which(labels==1)]))
c2 <- c(mean(x[which(labels==2)]), mean(y[which(labels==2)]))
c3 <- c(mean(x[which(labels==3)]), mean(y[which(labels==3)]))
plot(x,y,col=c("red","green","blue")[labels], cex=0.5)
points(c1[1],c1[2], col="red", pch=19)
points(c2[1],c2[2], col="green", pch=19)
points(c3[1],c3[2], col="blue", pch=19)
# After one iteration
# The iteration helps to stabilize the clustering
# At the end, when reach iteration=10, iteration stop
invisible(readline())
}
for (i in 1:nite){
# Calculate the distance from the center to the datapoints
