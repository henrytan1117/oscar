ideal_Sosa_model <- Sosa_models$Cubic
Sosa_result <- optimize(
f = function(age) predict(ideal_Sosa_model, newdata=data.frame(Age=age)),
interval=c(min(Sosa$Age), max(Sosa$Age)),
maximum = TRUE
)
ideal_Ruth_model <- Ruth_models$Quadratic
Ruth_result <- optimize(
f = function(age) predict(ideal_Ruth_model, newdata=data.frame(Age=age)),
interval=c(min(Ruth$Age), max(Ruth$Age)),
maximum = TRUE
)
# Empirical maximum (actual data)
Sosa_empirical_max_age <- Sosa$Age[which.max(Sosa$HR)]
Sosa_empirical_max_HR <- max(Sosa$HR)
Ruth_empirical_max_age <- Ruth$Age[which.max(Ruth$HR)]
Ruth_empirical_max_HR <- max(Ruth$HR)
# Create comparison table
data.frame(
Player = c("Sosa", "Ruth"),
Model_Peak_Age = c(Sosa_result$maximum, Ruth_result$maximum),
Empirical_Peak_Age = c(Sosa_empirical_max_age, Ruth_empirical_max_age),
Predicted_Max_HR = c(Sosa_result$objective, Ruth_result$objective),
Empirical_Max_HR = c(Sosa_empirical_max_HR, Ruth_empirical_max_HR)
)
# Sosa at age 30.99
Sosa_PI <- predict(ideal_Sosa_model,
newdata = data.frame(Age = Sosa_result$maximum),
interval = "prediction",
level = 0.95)
# Ruth at age 31.06
Ruth_PI <- predict(ideal_Ruth_model,
newdata = data.frame(Age = Ruth_result$maximum),
interval = "prediction",
level = 0.95)
# Display results
rbind(
data.frame(Player = "Sosa", fit = Sosa_PI[1], lwr = Sosa_PI[2], upr = Sosa_PI[3]),
data.frame(Player = "Ruth", fit = Ruth_PI[1], lwr = Ruth_PI[2], upr = Ruth_PI[3])
)
Sosa_PI <- predict(ideal_Sosa_model,
newdata = data.frame(Age = Sosa_result$maximum),
interval = "prediction",
level = 0.95)
Ruth_PI <- predict(ideal_Ruth_model,
newdata = data.frame(Age = Ruth_result$maximum),
interval = "prediction",
level = 0.95)
rbind(
data.frame(Player = "Sosa", fit = Sosa_PI[1], lwr = Sosa_PI[2], upr = Sosa_PI[3]),
data.frame(Player = "Ruth", fit = Ruth_PI[1], lwr = Ruth_PI[2], upr = Ruth_PI[3])
)
