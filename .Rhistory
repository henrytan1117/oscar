library(vip)
# 1. Define the prediction wrapper function
# This tells vip how to get the 'win' probability from your model
pfun <- function(object, newdata) {
predict(object, newdata, type = "prob")[, "1"]
}
# 2. Run vip with the wrapper
vip.plot <- vip(rf_strata,
method = "permute",
target = "best_picture_winner",
metric = "accuracy",
train = dat,
pred_wrapper = pfun,
nsim = 5)
