table(bordeaux$CultWine)
data(mcycle)
x <- mcycle$times
y <- mcycle$accel
plot(x, y,
xlab = "Time (ms) after impact",
ylab = "Acceleration (g)",
main = "Motorcycle Head Acceleration Data",
pch = 16, col = "blue")
par(mfrow = c(2, 5))
for (d in 1:10) {
# Fit polynomial model of degree d
poly_model <- lm(y ~ poly(x, degree = d, raw = TRUE))
plot(x, y,
xlab = "Time (ms)",
ylab = "Acceleration (g)",
main = paste("Degree", d, "Polynomial"),
pch = 16, col = "lightblue", cex = 0.8)
x_seq <- seq(min(x), max(x), length.out = 200)
y_pred <- predict(poly_model, newdata = data.frame(x = x_seq))
lines(x_seq, y_pred, col = "red", lwd = 2)
}
par(mfrow = c(1, 1))
fit_linear_spline <- function(x, y, n_knots) {
# Create equally-spaced knots
knots <- seq(min(x), max(x), length.out = n_knots + 2)[2:(n_knots + 1)]
X <- outer(x, knots, function(x, k) pmax(x - k, 0))
spline_model <- lm(y ~ x + X)
return(spline_model)
}
par(mfrow = c(1, 3))
for (n_knots in c(10, 20, 100)) {
spline_model <- fit_linear_spline(x, y, n_knots)
plot(x, y,
xlab = "Time (ms)",
ylab = "Acceleration (g)",
main = paste(n_knots, "Knots Linear Spline"),
pch = 16, col = "lightblue", cex = 0.8)
x_seq <- seq(min(x), max(x), length.out = 500)
X_new <- outer(x_seq, seq(min(x), max(x), length.out = n_knots + 2)[2:(n_knots + 1)],
function(x, k) pmax(x - k, 0))
y_pred <- predict(spline_model, newdata = data.frame(x = x_seq, X = X_new))
lines(x_seq, y_pred, col = "red", lwd = 2)
}
library(splines)
par(mfrow = c(1, 3))
# splines with 10, 20, and 100 knots
for (n_knots in c(10, 20, 100)) {
spline_model <- lm(y ~ bs(x, knots = seq(min(x), max(x), length.out = n_knots + 2)[2:(n_knots + 1)], degree = 1))
plot(x, y,
xlab = "Time (ms)",
ylab = "Acceleration (g)",
main = paste(n_knots, "Knots Linear Spline"),
pch = 16, col = "lightblue", cex = 0.8)
x_seq <- seq(min(x), max(x), length.out = 500)
y_pred <- predict(spline_model, newdata = data.frame(x = x_seq))
lines(x_seq, y_pred, col = "red", lwd = 2)
}
par(mfrow = c(1, 1))
gam_spline <- gam(y ~ s(x))
plot(x, y,
xlab = "Time (ms)",
ylab = "Acceleration (g)",
main = "GAM Smooth Spline",
pch = 16, col = "lightblue", cex = 0.8)
x_seq <- seq(min(x), max(x), length.out = 500)
y_pred <- predict(gam_spline, newdata = data.frame(x = x_seq))
lines(x_seq, y_pred, col = "red", lwd = 2)
summary(gam_spline)
