set.seed(456) # Always set a seed for reproducibility
rf.model <- randomForest(as.factor(best_picture_winner) ~ .,
data = dat,
importance = TRUE,
ntree = 500,
mtry = 3) # mtry = sqrt(number of predictors) is a good start
# 3. Plot the Importance
# MeanDecreaseGini is the best metric for "importance"
varImpPlot(rf.model, type = 2, main = "Variable Importance (Random Forest)")
# Simply print the model object
print(rf.model)
# Plot the error rate over the number of trees
# Look for where the error rate "flattens out"
plot(rf.model)
install.packages("vip")
library(vip)
# This calculates importance based on permutation (accuracy reduction)
vip(rf.model, method = "permute", target = "best_picture_winner", metric = "accuracy")
levels(as.factor(dat$best_picture_winner))
library(randomForest)
# 2. Build the forest
# We set ntree to 500 to stabilize the results
# importance = TRUE allows us to extract the importance metrics
# 1. Define weights:
# The number of losers (0s) vs winners (1s) is roughly 175 to 26.
# We give the '1' class a weight of ~6.7 to balance the importance (175/26 = 6.7)
rf_balanced <- randomForest(as.factor(best_picture_winner) ~ .,
data = dat,
importance = TRUE,
ntree = 500,
mtry = 3,
classwt = c(1, 6.73)) # Adjust based on your actual counts
# 2. Check the new confusion matrix
print(rf_balanced)
# 3. Re-generate Variable Importance
varImpPlot(rf_balanced, type = 2)
# Simply print the model object
print(rf.model)
# Plot the error rate over the number of trees
# Look for where the error rate "flattens out"
plot(rf.model)
# Simply print the model object
print(rf.balanced)
